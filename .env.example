# ============================================================================
# Turso Database Configuration
# ============================================================================
# Para obtener estos valores:
# 1. Crear cuenta en https://turso.tech/
# 2. Crear una base de datos: turso db create <nombre-db>
# 3. Obtener URL: turso db show <nombre-db> --url
# 4. Crear token: turso db tokens create <nombre-db>
# 5. Para Vercel: Configurar estas variables en Project Settings > Environment Variables

TURSO_DATABASE_URL=libsql://<nombre-db>-<usuario>.turso.io
TURSO_AUTH_TOKEN=<tu-auth-token-aqui>

# ============================================================================
# Site Configuration (opcional)
# ============================================================================
SITE_URL=https://blog.beresiarte.xyz
