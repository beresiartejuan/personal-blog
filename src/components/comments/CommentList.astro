---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="comments-feed" data-post-slug={postSlug}>
  <div class="loading-placeholder">
    <div class="skeleton-avatar"></div>
    <div class="skeleton-content">
      <div class="skeleton-line name"></div>
      <div class="skeleton-line"></div>
      <div class="skeleton-line short"></div>
    </div>
  </div>
</div>

<style>
  .comments-feed {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  /* Loading state */
  .loading-placeholder {
    display: flex;
    gap: 1rem;
    padding: 1rem 0;
    opacity: 0.5;
    animation: pulse 2s ease-in-out infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 0.4; }
    50% { opacity: 0.7; }
  }

  .skeleton-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: #2a2a2f;
    flex-shrink: 0;
  }

  .skeleton-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding-top: 0.25rem;
  }

  .skeleton-line {
    height: 14px;
    background: #2a2a2f;
    border-radius: 3px;
    width: 100%;
  }

  .skeleton-line.name {
    width: 100px;
    height: 12px;
  }

  .skeleton-line.short {
    width: 60%;
  }

  /* Empty state */
  .empty-feed {
    text-align: center;
    padding: 3rem 2rem;
    color: #52525b;
  }

  .empty-icon {
    font-size: 2rem;
    margin-bottom: 0.5rem;
    opacity: 0.6;
  }

  .empty-text {
    font-size: 0.9375rem;
    margin: 0;
  }

  /* Comment cards */
  .comment-card {
    display: flex;
    gap: 0.875rem;
    padding: 1.25rem;
    background: #141418;
    border: 1px solid #1f1f25;
    border-radius: 12px;
    transition: all 0.2s ease;
  }

  .comment-card:hover {
    border-color: #2a2a35;
    background: #1a1a1f;
  }

  .comment-card.own-comment {
    background: linear-gradient(135deg, rgba(255, 107, 53, 0.05) 0%, #141418 100%);
    border-color: rgba(255, 107, 53, 0.3);
    box-shadow: 0 0 20px rgba(255, 107, 53, 0.05);
  }

  /* Avatar */
  .comment-avatar {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    overflow: hidden;
    background: linear-gradient(135deg, #2a2a2f 0%, #1a1a1f 100%);
    border: 2px solid #2a2a2f;
    position: relative;
  }

  .comment-card.own-comment .comment-avatar {
    border-color: #ff6b35;
  }

  .comment-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .comment-avatar img.loaded {
    opacity: 1;
  }

  .comment-avatar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #3a3a45 0%, #2a2a2f 100%);
    z-index: 0;
  }

  /* Content */
  .comment-body {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* The comment text - HERO */
  .comment-text {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: #e4e4e7;
    margin: 0;
    word-wrap: break-word;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  /* Meta - SECONDARY */
  .comment-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 0.25rem;
  }

  .author-name {
    font-size: 0.8125rem;
    font-weight: 600;
    color: #a1a1aa;
  }

  .comment-card.own-comment .author-name {
    color: #ff8555;
  }

  .meta-separator {
    color: #3a3a45;
    font-size: 0.75rem;
  }

  .timestamp {
    font-size: 0.75rem;
    color: #52525b;
    font-weight: 400;
  }

  .you-badge {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: rgba(255, 107, 53, 0.15);
    color: #ff6b35;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .flag-badge {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
    border-radius: 4px;
    font-weight: 500;
  }

  /* Error state */
  .error-feed {
    text-align: center;
    padding: 2rem;
    color: #ef4444;
    background: rgba(239, 68, 68, 0.05);
    border-radius: 8px;
  }

  @media (max-width: 640px) {
    .comment-card {
      padding: 1rem;
      gap: 0.75rem;
    }

    .comment-avatar {
      width: 36px;
      height: 36px;
    }

    .comment-text {
      font-size: 1rem;
    }

    .author-name {
      font-size: 0.75rem;
    }
  }
</style>

<script>
  import { getAnonymousId } from "@/lib/visitor";
  import { actions } from "astro:actions";
  import { formatDistanceToNow } from "date-fns";
  import { es } from "date-fns/locale";

  const container = document.querySelector(".comments-feed");
  const currentAnonymousId = getAnonymousId();

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderComment(comment: any): string {
    const date = new Date(comment.createdAt);
    const timeAgo = formatDistanceToNow(date, { addSuffix: false, locale: es });
    const isOwn = comment.anonymousId === currentAnonymousId;
    
    return `
      <article class="comment-card ${isOwn ? 'own-comment' : ''}" data-anonymous-id="${comment.anonymousId}">
        <div class="comment-avatar">
          <img 
            src="https://api.dicebear.com/10.x/lorelei-neutral/svg?seed=${encodeURIComponent(comment.anonymousId)}"
            alt=""
            loading="lazy"
            onload="this.classList.add('loaded')"
          />
        </div>
        <div class="comment-body">
          <p class="comment-text">${escapeHtml(comment.content)}</p>
          <div class="comment-meta">
            ${isOwn 
              ? '<span class="you-badge">Tú</span>' 
              : `<span class="author-name">${escapeHtml(comment.authorName || "Anónimo")}</span>`
            }
            <span class="meta-separator">·</span>
            <time class="timestamp" title="${date.toLocaleString("es-ES")}">${timeAgo}</time>
            ${comment.isFlagged ? '<span class="flag-badge">⚠️ Censurado</span>' : ""}
          </div>
        </div>
      </article>
    `;
  }

  async function loadComments() {
    const postSlug = container?.getAttribute("data-post-slug");
    if (!postSlug || !container) return;

    try {
      const { data } = await actions.getComments({ postSlug });
      const comments = data?.comments || [];

      if (comments.length === 0) {
        container.innerHTML = `
          <div class="empty-feed">
            <div class="empty-icon">💭</div>
            <p class="empty-text">Aún no hay comentarios. Sé el primero.</p>
          </div>
        `;
        return;
      }

      container.innerHTML = comments.map(renderComment).join("");
    } catch (error) {
      console.error("Error loading comments:", error);
      container.innerHTML = `
        <div class="error-feed">
          <p>No se pudieron cargar los comentarios</p>
        </div>
      `;
    }
  }

  loadComments();
  window.addEventListener("comment-submitted", loadComments);
</script>
