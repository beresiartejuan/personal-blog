---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="comments-stage" data-post-slug={postSlug}>
  <div class="stage-loading">
    <div class="spinner"></div>
    <span>Cargando conversación...</span>
  </div>
</div>

<style>
  /* Paleta específica para comentarios */
  :root {
    --comment-bg: #111114;
    --comment-border: #1e1e24;
    --comment-border-hover: #2d2d35;
    --text-primary: #f0f0f5;
    --text-secondary: #8b8b97;
    --text-tertiary: #5a5a66;
    --accent-orange: #ff6b35;
    --accent-orange-soft: rgba(255, 107, 53, 0.08);
    --avatar-bg: #25252c;
  }

  .comments-stage {
    display: flex;
    flex-direction: column;
    gap: 0;
    max-width: 680px;
    margin: 0 auto;
  }

  /* Loading state */
  .stage-loading {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 4rem 2rem;
    color: var(--text-tertiary);
    font-size: 0.875rem;
    gap: 1rem;
  }

  .spinner {
    width: 32px;
    height: 32px;
    border: 2px solid var(--comment-border);
    border-top-color: var(--accent-orange);
    border-radius: 50%;
    animation: spin 0.8s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  /* Empty state */
  .stage-empty {
    text-align: center;
    padding: 4rem 2rem;
    color: var(--text-tertiary);
  }

  .empty-illustration {
    width: 64px;
    height: 64px;
    margin: 0 auto 1.5rem;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--comment-border) 0%, var(--comment-bg) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.5rem;
    opacity: 0.6;
  }

  .empty-text {
    font-size: 1rem;
    margin: 0;
    font-weight: 400;
  }

  .empty-hint {
    font-size: 0.8125rem;
    margin: 0.5rem 0 0;
    opacity: 0.7;
  }

  /* Comment blocks - cada uno es una "escena" */
  .comment-scene {
    position: relative;
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--comment-border);
    transition: all 0.2s ease;
  }

  .comment-scene:last-child {
    border-bottom: none;
  }

  .comment-scene:hover {
    background: linear-gradient(90deg, transparent 0%, rgba(255,255,255,0.01) 50%, transparent 100%);
  }

  /* Layout horizontal: avatar | contenido */
  .comment-block {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.25rem;
    align-items: start;
  }

  /* AVATAR - con tamaño fijo y reservado */
  .avatar-slot {
    position: relative;
    width: 56px;
    height: 56px;
    flex-shrink: 0;
  }

  .avatar-frame {
    width: 100%;
    height: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: var(--avatar-bg);
    position: relative;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .comment-scene:hover .avatar-frame {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.3);
  }

  /* Placeholder mientras carga */
  .avatar-frame::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #2a2a32 0%, #1f1f25 100%);
    z-index: 1;
  }

  .avatar-frame img {
    position: relative;
    z-index: 2;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .avatar-frame img.loaded {
    opacity: 1;
  }

  /* Anillo para usuario actual */
  .avatar-ring {
    position: absolute;
    inset: -3px;
    border-radius: 16px;
    border: 2px solid transparent;
    pointer-events: none;
    transition: border-color 0.2s ease;
  }

  .comment-scene.own .avatar-ring {
    border-color: var(--accent-orange);
  }

  /* CONTENIDO - jerarquía tipográfica clara */
  .content-area {
    display: flex;
    flex-direction: column;
    gap: 0.625rem;
    padding-top: 0.25rem;
  }

  /* NIVEL 1: El comentario (más importante) */
  .comment-voice {
    font-size: 1.0625rem;
    line-height: 1.55;
    color: var(--text-primary);
    margin: 0;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  /* NIVEL 2: Metadata (menos importante) */
  .comment-identity {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .author-mark {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
  }

  .comment-scene.own .author-mark {
    color: var(--accent-orange);
  }

  .time-mark {
    font-size: 0.75rem;
    color: var(--text-tertiary);
    font-weight: 400;
  }

  .separator {
    color: var(--text-tertiary);
    font-size: 0.625rem;
    opacity: 0.5;
  }

  /* Badges */
  .badge {
    font-size: 0.6875rem;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .badge-you {
    background: var(--accent-orange-soft);
    color: var(--accent-orange);
    border: 1px solid rgba(255, 107, 53, 0.2);
  }

  .badge-flagged {
    background: rgba(245, 158, 11, 0.1);
    color: #f59e0b;
    border: 1px solid rgba(245, 158, 11, 0.2);
  }

  /* Error state */
  .stage-error {
    text-align: center;
    padding: 3rem 2rem;
    color: #ef4444;
  }

  .stage-error p {
    margin: 0;
    font-size: 0.9375rem;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .comment-block {
      grid-template-columns: 44px 1fr;
      gap: 1rem;
    }

    .avatar-slot {
      width: 44px;
      height: 44px;
    }

    .avatar-frame {
      border-radius: 12px;
    }

    .avatar-ring {
      border-radius: 14px;
    }

    .comment-voice {
      font-size: 1rem;
    }

    .comment-scene {
      padding: 1.25rem 0;
    }
  }
</style>

<script>
  import { getAnonymousId } from "@/lib/visitor";
  import { actions } from "astro:actions";
  import { formatDistanceToNow } from "date-fns";
  import { es } from "date-fns/locale";

  const stage = document.querySelector(".comments-stage");
  const currentId = getAnonymousId();

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  function renderScene(comment: any): string {
    const date = new Date(comment.createdAt);
    const timeAgo = formatDistanceToNow(date, { addSuffix: false, locale: es });
    const isOwn = comment.anonymousId === currentId;
    
    return `
      <div class="comment-scene ${isOwn ? 'own' : ''}" data-id="${comment.anonymousId}">
        <div class="comment-block">
          <div class="avatar-slot">
            <div class="avatar-ring"></div>
            <div class="avatar-frame">
              <img 
                src="https://api.dicebear.com/10.x/lorelei-neutral/svg?seed=${encodeURIComponent(comment.anonymousId)}"
                alt=""
                loading="lazy"
                onload="this.classList.add('loaded')"
              />
            </div>
          </div>
          
          <div class="content-area">
            <p class="comment-voice">${escapeHtml(comment.content)}</p>
            
            <div class="comment-identity">
              ${isOwn 
                ? '<span class="badge badge-you">Tú</span>'
                : `<span class="author-mark">${escapeHtml(comment.authorName || "Anónimo")}</span>`
              }
              <span class="separator">·</span>
              <time class="time-mark" title="${date.toLocaleString('es-ES')}">${timeAgo}</time>
              ${comment.isFlagged ? '<span class="badge badge-flagged">Censurado</span>' : ''}
            </div>
          </div>
        </div>
      </div>
    `;
  }

  async function loadComments() {
    const postSlug = stage?.getAttribute("data-post-slug");
    if (!postSlug || !stage) return;

    try {
      const { data } = await actions.getComments({ postSlug });
      const comments = data?.comments || [];

      if (comments.length === 0) {
        stage.innerHTML = `
          <div class="stage-empty">
            <div class="empty-illustration">💭</div>
            <p class="empty-text">Silencio por ahora</p>
            <p class="empty-hint">Sé el primero en romperlo</p>
          </div>
        `;
        return;
      }

      stage.innerHTML = comments.map(renderScene).join("");
    } catch (error) {
      console.error("Error loading comments:", error);
      stage.innerHTML = `
        <div class="stage-error">
          <p>No se pudieron cargar los comentarios</p>
        </div>
      `;
    }
  }

  loadComments();
  window.addEventListener("comment-submitted", loadComments);
</script>
