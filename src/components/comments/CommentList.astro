---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="comments-section">
  <h3 class="comments-title">
    <span class="comments-count">...</span>
  </h3>

  <div id="comments-container" class="comments-container" data-post-slug={postSlug}>
    <div class="loading-comments">
      <div class="loading-avatar skeleton"></div>
      <div class="loading-content">
        <div class="loading-line skeleton" style="width: 120px;"></div>
        <div class="loading-line skeleton" style="width: 100%;"></div>
        <div class="loading-line skeleton" style="width: 80%;"></div>
      </div>
    </div>
  </div>
</div>

<style>
  .comments-section {
    margin-top: 2rem;
  }

  .comments-title {
    color: #e4e4e7;
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 1.5rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid #2a2a2f;
  }

  .comments-container {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  /* Skeleton loading */
  .loading-comments {
    display: flex;
    gap: 0.875rem;
    padding: 1rem;
    background: #1a1a1f;
    border: 1px solid #2a2a2f;
    border-radius: 8px;
  }

  .loading-avatar {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .loading-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .loading-line {
    height: 0.875rem;
    border-radius: 4px;
  }

  .skeleton {
    background: linear-gradient(90deg, #2a2a2f 25%, #3a3a3f 50%, #2a2a2f 75%);
    background-size: 200% 100%;
    animation: shimmer 1.5s infinite;
  }

  @keyframes shimmer {
    0% { background-position: 200% 0; }
    100% { background-position: -200% 0; }
  }

  /* No comments state */
  .no-comments {
    text-align: center;
    padding: 2.5rem 1.5rem;
    color: #71717a;
    font-style: italic;
    background: #1a1a1f;
    border-radius: 8px;
    border: 1px dashed #3a3a3f;
  }

  /* Comment item */
  .comment-item {
    display: flex;
    gap: 0.875rem;
    padding: 1rem;
    background: #1a1a1f;
    border: 1px solid #2a2a2f;
    border-radius: 8px;
    transition: border-color 0.2s ease;
  }

  .comment-item:hover {
    border-color: #3a3a3f;
  }

  .comment-item.current-user {
    border-color: #4a9eff;
    background: linear-gradient(135deg, #1a1a1f 0%, #1e2a3a 100%);
  }

  /* Avatar con aspect-ratio para evitar saltos */
  .comment-avatar {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    overflow: hidden;
    background: #2a2a2f;
    border: 2px solid #3a3a3f;
    position: relative;
    aspect-ratio: 1 / 1;
  }

  .comment-avatar::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #2a2a2f 0%, #1a1a1f 100%);
    z-index: 0;
  }

  .comment-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    position: relative;
    z-index: 1;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .comment-avatar img.loaded {
    opacity: 1;
  }

  /* Content layout */
  .comment-content {
    flex: 1;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .comment-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .comment-author {
    color: #ff6b35;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .comment-meta {
    display: flex;
    align-items: center;
    gap: 0.375rem;
  }

  .comment-date {
    color: #71717a;
    font-size: 0.75rem;
  }

  .current-user-badge {
    font-size: 0.625rem;
    padding: 0.125rem 0.375rem;
    background: #4a9eff;
    color: #0a0a0f;
    border-radius: 4px;
    font-weight: 600;
  }

  .flag-badge {
    font-size: 0.6875rem;
    padding: 0.125rem 0.375rem;
    background: rgba(245, 158, 11, 0.15);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: #f59e0b;
    border-radius: 4px;
  }

  .comment-text {
    color: #d4d4d8;
    font-size: 0.9375rem;
    line-height: 1.6;
    margin: 0;
    word-wrap: break-word;
  }

  /* Error state */
  .error-comments {
    text-align: center;
    padding: 2rem;
    color: #ef4444;
    background: rgba(239, 68, 68, 0.05);
    border-radius: 8px;
    border: 1px solid rgba(239, 68, 68, 0.2);
  }

  @media (max-width: 640px) {
    .comment-item {
      padding: 0.875rem;
      gap: 0.75rem;
    }

    .comment-avatar {
      width: 28px;
      height: 28px;
    }

    .comment-header {
      gap: 0.375rem;
    }
  }
</style>

<script>
  import { getAnonymousId } from "@/lib/visitor";
  import { actions } from "astro:actions";
  import { formatDistanceToNow } from "date-fns";
  import { es } from "date-fns/locale";

  const container = document.getElementById("comments-container");
  const currentAnonymousId = getAnonymousId();

  function renderComment(comment: any): string {
    const date = new Date(comment.createdAt);
    const timeAgo = formatDistanceToNow(date, { addSuffix: true, locale: es });
    const isCurrentUser = comment.anonymousId === currentAnonymousId;
    
    return `
      <article class="comment-item ${isCurrentUser ? 'current-user' : ''}" data-anonymous-id="${comment.anonymousId}">
        <div class="comment-avatar">
          <img 
            src="https://api.dicebear.com/10.x/lorelei-neutral/svg?seed=${encodeURIComponent(comment.anonymousId)}"
            alt=""
            loading="lazy"
            width="32"
            height="32"
            onload="this.classList.add('loaded')"
          />
        </div>
        <div class="comment-content">
          <header class="comment-header">
            <span class="comment-author">
              ${escapeHtml(comment.authorName || "Anónimo")}
            </span>
            <span class="comment-meta">
              <span class="comment-date" title="${date.toLocaleString("es-ES")}">
                ${timeAgo}
              </span>
              ${isCurrentUser ? '<span class="current-user-badge">Tú</span>' : ''}
              ${comment.isFlagged ? `
                <span class="flag-badge" title="Contenido censurado por lenguaje inapropiado">
                  ⚠️ Censurado
                </span>
              ` : ""}
            </span>
          </header>
          <p class="comment-text">${escapeHtml(comment.content)}</p>
        </div>
      </article>
    `;
  }

  function escapeHtml(text: string): string {
    const div = document.createElement('div');
    div.textContent = text;
    return div.innerHTML;
  }

  // Cargar comentarios iniciales
  async function loadComments() {
    const postSlug = container?.getAttribute("data-post-slug");
    if (!postSlug || !container) return;

    try {
      const { data } = await actions.getComments({ postSlug });
      const comments = data?.comments || [];

      // Actualizar título
      const titleElement = document.querySelector(".comments-count");
      if (titleElement) {
        titleElement.textContent = comments.length === 0 
          ? "Sin comentarios" 
          : `${comments.length} ${comments.length === 1 ? 'comentario' : 'comentarios'}`;
      }

      if (comments.length === 0) {
        container.innerHTML = `
          <div class="no-comments">
            <p>Sé el primero en comentar 📝</p>
          </div>
        `;
        return;
      }

      container.innerHTML = comments.map(renderComment).join("");
    } catch (error) {
      console.error("Error loading comments:", error);
      container.innerHTML = `
        <div class="error-comments">
          <p>No se pudieron cargar los comentarios. Intenta recargar la página.</p>
        </div>
      `;
    }
  }

  // Recargar comentarios (llamado después de enviar uno nuevo)
  async function reloadComments() {
    await loadComments();
  }

  // Cargar al iniciar
  loadComments();

  // Escuchar evento de nuevo comentario
  window.addEventListener("comment-submitted", reloadComments);
</script>
