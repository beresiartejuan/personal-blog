---
import CommentForm from "./CommentForm.astro";
import CommentList from "./CommentList.astro";
import VisitCounter from "./VisitCounter.astro";

interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<section class="comments-section" aria-label="Comentarios">
  <div class="section-header">
    <div class="header-main">
      <h2 class="section-title">Comentarios</h2>
      <VisitCounter postSlug={postSlug} />
    </div>
    <p class="section-subtitle">Un espacio para compartir ideas y perspectivas</p>
  </div>

  <div class="comments-flow">
    <CommentForm postSlug={postSlug} />
    <CommentList postSlug={postSlug} />
  </div>
</section>

<style>
  .comments-section {
    margin-top: 4rem;
    padding-top: 3rem;
    border-top: 1px solid #2a2a2f;
  }

  .section-header {
    margin-bottom: 2rem;
  }

  .header-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #e4e4e7;
    margin: 0;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    font-size: 0.9375rem;
    color: #71717a;
    margin: 0;
    line-height: 1.5;
  }

  .comments-flow {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .comments-section {
      margin-top: 3rem;
      padding-top: 2rem;
    }

    .section-title {
      font-size: 1.25rem;
    }

    .section-subtitle {
      font-size: 0.875rem;
    }
  }
</style>
