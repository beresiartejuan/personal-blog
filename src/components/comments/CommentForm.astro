---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="comment-composer" data-post-slug={postSlug}>
  <div class="composer-header">
    <span class="composer-label">Añadir comentario</span>
  </div>
  
  <form id="comment-form" class="comment-form">
    {/* Campo trampa */}
    <div class="honeypot-field" aria-hidden="true">
      <input type="text" name="website" tabindex="-1" autocomplete="off" />
    </div>

    <div class="composer-body">
      <div class="form-field">
        <input 
          type="text" 
          id="author-name" 
          name="authorName" 
          maxlength="50"
          placeholder="Tu nombre (opcional)"
          class="name-input"
        />
      </div>

      <div class="form-field">
        <textarea 
          id="comment-content" 
          name="content" 
          rows="3" 
          maxlength="2000"
          required
          placeholder="¿Qué piensas?"
          class="content-input"
        ></textarea>
        <div class="composer-footer">
          <span class="char-count">0/2000</span>
          <button type="submit" class="submit-btn" disabled>
            <span class="btn-text">Publicar</span>
            <span class="btn-loader">
              <svg width="16" height="16" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" stroke-dasharray="31.416" stroke-dashoffset="31.416">
                  <animate attributeName="stroke-dashoffset" from="31.416" to="0" dur="1s" repeatCount="indefinite" />
                </circle>
              </svg>
            </span>
          </button>
        </div>
      </div>
    </div>
  </form>

  <div id="form-message" class="form-message" role="alert"></div>
</div>

<style>
  .comment-composer {
    margin-bottom: 1.5rem;
    background: #151519;
    border: 1px solid #2a2a2f;
    border-radius: 12px;
    overflow: hidden;
  }

  .composer-header {
    padding: 0.875rem 1.25rem;
    background: #1a1a1f;
    border-bottom: 1px solid #2a2a2f;
  }

  .composer-label {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #71717a;
  }

  .composer-body {
    padding: 1.25rem;
  }

  .honeypot-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
  }

  .form-field {
    margin-bottom: 1rem;
  }

  .form-field:last-child {
    margin-bottom: 0;
  }

  .name-input {
    width: 100%;
    background: transparent;
    border: none;
    border-bottom: 1px solid #2a2a2f;
    padding: 0.5rem 0;
    color: #e4e4e7;
    font-size: 0.875rem;
    font-weight: 500;
    transition: border-color 0.2s ease;
  }

  .name-input:focus {
    outline: none;
    border-color: #ff6b35;
  }

  .name-input::placeholder {
    color: #52525b;
  }

  .content-input {
    width: 100%;
    background: transparent;
    border: none;
    padding: 0.5rem 0;
    color: #e4e4e7;
    font-size: 1rem;
    line-height: 1.6;
    resize: none;
    min-height: 80px;
    font-family: inherit;
  }

  .content-input:focus {
    outline: none;
  }

  .content-input::placeholder {
    color: #52525b;
  }

  .composer-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.75rem;
    border-top: 1px solid #2a2a2f;
  }

  .char-count {
    font-size: 0.75rem;
    color: #52525b;
    font-weight: 500;
  }

  .char-count.near-limit {
    color: #f59e0b;
  }

  .submit-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.625rem 1.25rem;
    background: #ff6b35;
    color: #0a0a0f;
    border: none;
    border-radius: 20px;
    font-size: 0.875rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .submit-btn:hover:not(:disabled) {
    background: #ff8555;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(255, 107, 53, 0.3);
  }

  .submit-btn:disabled {
    background: #2a2a2f;
    color: #52525b;
    cursor: not-allowed;
  }

  .btn-loader {
    display: none;
    animation: spin 1s linear infinite;
  }

  .btn-loader svg {
    display: block;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .submit-btn.loading .btn-text {
    display: none;
  }

  .submit-btn.loading .btn-loader {
    display: block;
  }

  .form-message {
    margin: 0 1.25rem 1.25rem;
    padding: 0.875rem 1rem;
    border-radius: 8px;
    font-size: 0.875rem;
    display: none;
  }

  .form-message.success {
    display: block;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    color: #22c55e;
  }

  .form-message.error {
    display: block;
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: #ef4444;
  }

  .form-message.warning {
    display: block;
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.2);
    color: #f59e0b;
  }

  @media (max-width: 640px) {
    .composer-header {
      padding: 0.75rem 1rem;
    }

    .composer-body {
      padding: 1rem;
    }

    .content-input {
      font-size: 0.9375rem;
    }

    .composer-footer {
      flex-wrap: wrap;
      gap: 0.75rem;
    }
  }
</style>

<script>
  import { actions } from "astro:actions";
  import { getAnonymousId } from "@/lib/visitor";

  const composer = document.querySelector(".comment-composer");
  const form = document.getElementById("comment-form") as HTMLFormElement;
  const contentInput = document.getElementById("comment-content") as HTMLTextAreaElement;
  const charCount = document.querySelector(".char-count") as HTMLElement;
  const submitBtn = form?.querySelector(".submit-btn") as HTMLButtonElement;
  const formMessage = document.getElementById("form-message") as HTMLElement;

  // Auto-resize textarea
  contentInput?.addEventListener("input", () => {
    const length = contentInput.value.length;
    charCount.textContent = `${length}/2000`;
    
    // Visual feedback near limit
    if (length > 1800) {
      charCount.classList.add("near-limit");
    } else {
      charCount.classList.remove("near-limit");
    }
    
    submitBtn.disabled = length === 0;
    
    // Auto-resize
    contentInput.style.height = "auto";
    contentInput.style.height = contentInput.scrollHeight + "px";
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    
    const postSlug = composer?.getAttribute("data-post-slug");
    const formData = new FormData(form);
    
    // Loading state
    submitBtn.disabled = true;
    submitBtn.classList.add("loading");
    formMessage.className = "form-message";
    formMessage.style.display = "none";

    try {
      const fingerprint = btoa(navigator.userAgent).slice(0, 16);
      
      const result = await actions.submitComment({
        postSlug: postSlug!,
        anonymousId: getAnonymousId(),
        authorName: formData.get("authorName") as string || undefined,
        content: formData.get("content") as string,
        honeypot: formData.get("website") as string || undefined,
        fingerprint,
      });

      if (result.data?.success) {
        form.reset();
        charCount.textContent = "0/2000";
        charCount.classList.remove("near-limit");
        contentInput.style.height = "auto";
        
        formMessage.textContent = result.data.message;
        formMessage.classList.add(result.data.message.includes("censurado") ? "warning" : "success");
        
        window.dispatchEvent(new CustomEvent("comment-submitted"));
      } else {
        formMessage.textContent = result.data?.message || "Error al enviar";
        formMessage.classList.add("error");
      }
    } catch (error) {
      console.error("Error:", error);
      formMessage.textContent = "Error de conexión. Intenta nuevamente.";
      formMessage.classList.add("error");
    } finally {
      submitBtn.disabled = false;
      submitBtn.classList.remove("loading");
    }
  });
</script>
