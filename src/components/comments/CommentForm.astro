---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<form id="comment-form" class="comment-form" data-post-slug={postSlug}>
  {/* Campo trampa - invisible para usuarios reales, visible para bots */}
  <div class="honeypot-field" aria-hidden="true">
    <input 
      type="text" 
      name="website" 
      id="website" 
      tabindex="-1" 
      autocomplete="off"
      placeholder="No llenar este campo"
    />
  </div>

  <div class="form-group">
    <label for="author-name">Nombre (opcional)</label>
    <input 
      type="text" 
      id="author-name" 
      name="authorName" 
      maxlength="50"
      placeholder="Anónimo"
      class="form-input"
    />
  </div>

  <div class="form-group">
    <label for="comment-content">
      Comentario <span class="required">*</span>
    </label>
    <textarea 
      id="comment-content" 
      name="content" 
      rows="4" 
      maxlength="2000"
      required
      placeholder="Escribe tu comentario..."
      class="form-textarea"
    ></textarea>
    <span class="char-count">0 / 2000</span>
  </div>

  <button type="submit" class="submit-button" disabled>
    <span class="button-text">Enviar comentario</span>
    <span class="button-loader" style="display: none;">Enviando...</span>
  </button>

  <div id="form-message" class="form-message" role="alert" style="display: none;"></div>
</form>

<style>
  .comment-form {
    background: #1a1a1f;
    border: 1px solid #2a2a2f;
    border-radius: 8px;
    padding: 1.5rem;
    margin-bottom: 2rem;
  }

  .honeypot-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    pointer-events: none;
  }

  .form-group {
    margin-bottom: 1.25rem;
  }

  label {
    display: block;
    color: #e4e4e7;
    font-size: 0.875rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }

  .required {
    color: #ff6b35;
  }

  .form-input,
  .form-textarea {
    width: 100%;
    background: #0a0a0f;
    border: 1px solid #3a3a3f;
    border-radius: 6px;
    padding: 0.75rem 1rem;
    color: #e4e4e7;
    font-size: 0.9375rem;
    transition: border-color 0.2s ease;
    font-family: inherit;
  }

  .form-input:focus,
  .form-textarea:focus {
    outline: none;
    border-color: #4a9eff;
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .char-count {
    display: block;
    text-align: right;
    color: #71717a;
    font-size: 0.75rem;
    margin-top: 0.25rem;
  }

  .submit-button {
    width: 100%;
    background: #ff6b35;
    color: #0a0a0f;
    border: none;
    border-radius: 6px;
    padding: 0.875rem 1.5rem;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .submit-button:hover:not(:disabled) {
    background: #ff8555;
    transform: translateY(-1px);
  }

  .submit-button:disabled {
    background: #3a3a3f;
    color: #71717a;
    cursor: not-allowed;
  }

  .form-message {
    margin-top: 1rem;
    padding: 0.875rem 1rem;
    border-radius: 6px;
    font-size: 0.875rem;
  }

  .form-message.success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.3);
    color: #22c55e;
  }

  .form-message.error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #ef4444;
  }

  .form-message.warning {
    background: rgba(245, 158, 11, 0.1);
    border: 1px solid rgba(245, 158, 11, 0.3);
    color: #f59e0b;
  }
</style>

<script>
  import { actions } from "astro:actions";
  import { getAnonymousId } from "@/lib/visitor";

  const form = document.getElementById("comment-form") as HTMLFormElement;
  const contentInput = document.getElementById("comment-content") as HTMLTextAreaElement;
  const charCount = document.querySelector(".char-count") as HTMLElement;
  const submitButton = form?.querySelector(".submit-button") as HTMLButtonElement;
  const buttonText = submitButton?.querySelector(".button-text") as HTMLElement;
  const buttonLoader = submitButton?.querySelector(".button-loader") as HTMLElement;
  const formMessage = document.getElementById("form-message") as HTMLElement;

  contentInput?.addEventListener("input", () => {
    const length = contentInput.value.length;
    charCount.textContent = `${length} / 2000`;
    submitButton.disabled = length === 0;
  });

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    
    const postSlug = form.dataset.postSlug;
    const formData = new FormData(form);
    
    submitButton.disabled = true;
    buttonText.style.display = "none";
    buttonLoader.style.display = "inline";
    formMessage.style.display = "none";
    formMessage.className = "form-message";

    try {
      const fingerprint = btoa(navigator.userAgent).slice(0, 16);
      
      const result = await actions.submitComment({
        postSlug: postSlug!,
        anonymousId: getAnonymousId(),
        authorName: formData.get("authorName") as string || undefined,
        content: formData.get("content") as string,
        honeypot: formData.get("website") as string || undefined,
        fingerprint,
      });

      if (result.data?.success) {
        form.reset();
        charCount.textContent = "0 / 2000";
        
        formMessage.textContent = result.data.message;
        formMessage.classList.add("success");
        formMessage.style.display = "block";

        window.dispatchEvent(new CustomEvent("comment-submitted"));
      } else {
        formMessage.textContent = result.data?.message || "Error al enviar el comentario";
        formMessage.classList.add("error");
        formMessage.style.display = "block";
      }
    } catch (error) {
      console.error("Error submitting comment:", error);
      formMessage.textContent = "Error de conexión. Por favor, intenta nuevamente.";
      formMessage.classList.add("error");
      formMessage.style.display = "block";
    } finally {
      submitButton.disabled = false;
      buttonText.style.display = "inline";
      buttonLoader.style.display = "none";
    }
  });
</script>
