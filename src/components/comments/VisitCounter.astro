---
import { actions } from "astro:actions";

interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;

// Obtener el conteo actual de visitas
const { data } = await actions.recordVisit({ postSlug, anonymousId: "server-side" });
const viewCount = data?.viewCount || 0;
---

<div class="visit-counter" data-post-slug={postSlug} data-initial-count={viewCount}>
  <span class="visit-icon">👁️</span>
  <span class="visit-count">{viewCount.toLocaleString("es-ES")}</span>
  <span class="visit-label">visitas</span>
</div>

<style>
  .visit-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background: #1a1a1f;
    border: 1px solid #2a2a2f;
    border-radius: 20px;
    color: #a1a1aa;
    font-size: 0.8125rem;
    transition: all 0.2s ease;
  }

  .visit-counter:hover {
    border-color: #3a3a3f;
    background: #202025;
  }

  .visit-icon {
    font-size: 0.875rem;
  }

  .visit-count {
    font-weight: 600;
    color: #e4e4e7;
  }

  .visit-label {
    color: #71717a;
  }
</style>

<script>
  import { actions } from "astro:actions";
  import { getAnonymousId } from "@/lib/visitor";

  const counter = document.querySelector(".visit-counter");
  const postSlug = counter?.getAttribute("data-post-slug");
  const countElement = counter?.querySelector(".visit-count");

  // Solo registrar visita del lado del cliente (no en SSR)
  if (postSlug && typeof window !== "undefined") {
    const anonymousId = getAnonymousId();
    
    // Registrar la visita y obtener el conteo actualizado
    actions.recordVisit({ postSlug, anonymousId })
      .then(({ data }) => {
        if (data?.viewCount && countElement) {
          // Animar el cambio de número
          animateNumber(countElement, data.viewCount);
        }
      })
      .catch((error) => {
        console.error("Error recording visit:", error);
      });
  }

  // Animación suave del número
  function animateNumber(element: Element, targetNumber: number): void {
    const currentText = element.textContent?.replace(/\./g, "") || "0";
    const currentNumber = parseInt(currentText, 10);
    
    if (currentNumber === targetNumber) return;

    const duration = 500;
    const startTime = performance.now();
    
    function update(currentTime: number): void {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      
      // Easing ease-out
      const easeOut = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(currentNumber + (targetNumber - currentNumber) * easeOut);
      
      element.textContent = current.toLocaleString("es-ES");
      
      if (progress < 1) {
        requestAnimationFrame(update);
      }
    }
    
    requestAnimationFrame(update);
  }
</script>