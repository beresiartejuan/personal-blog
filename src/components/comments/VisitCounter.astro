---
interface Props {
  postSlug: string;
}

const { postSlug } = Astro.props;
---

<div class="visit-counter" data-post-slug={postSlug}>
  <span class="visit-icon">👁️</span>
  <span class="visit-count">...</span>
  <span class="visit-label">visitas</span>
</div>

<style>
  .visit-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 0.875rem;
    background: #1a1a1f;
    border: 1px solid #2a2a2f;
    border-radius: 20px;
    color: #a1a1aa;
    font-size: 0.8125rem;
    transition: all 0.2s ease;
  }

  .visit-counter:hover {
    border-color: #3a3a3f;
    background: #202025;
  }

  .visit-icon {
    font-size: 0.875rem;
  }

  .visit-count {
    font-weight: 600;
    color: #e4e4e7;
  }

  .visit-label {
    color: #71717a;
  }
</style>

<script>
  import { actions } from "astro:actions";
  import { getAnonymousId } from "@/lib/visitor";

  const counters = document.querySelectorAll(".visit-counter");

  counters.forEach((counter) => {
    const postSlug = counter.getAttribute("data-post-slug");
    const countElement = counter.querySelector(".visit-count");
    
    if (!postSlug || !countElement) return;

    const anonymousId = getAnonymousId();
    
    // Registrar la visita y obtener el conteo actualizado
    actions.recordVisit({ postSlug, anonymousId })
      .then(({ data }) => {
        if (data?.viewCount) {
          animateNumber(countElement, data.viewCount);
        }
      })
      .catch((error) => {
        console.error("Error recording visit:", error);
        countElement.textContent = "0";
      });
  });

  // Animación suave del número
  function animateNumber(element: Element, targetNumber: number): void {
    const duration = 800;
    const startTime = performance.now();
    
    function update(currentTime: number): void {
      const elapsed = currentTime - startTime;
      const progress = Math.min(elapsed / duration, 1);
      
      // Easing ease-out
      const easeOut = 1 - Math.pow(1 - progress, 3);
      const current = Math.round(targetNumber * easeOut);
      
      element.textContent = current.toLocaleString("es-ES");
      
      if (progress < 1) {
        requestAnimationFrame(update);
      }
    }
    
    requestAnimationFrame(update);
  }
</script>
