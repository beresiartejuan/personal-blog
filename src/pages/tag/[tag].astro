---
import Layout from '../../layouts/Layout.astro';
import { SITE, ROUTES, NAV_LABELS, TERMINAL_PROMPTS, CONTENT, MESSAGES } from '../../config';
import { getAllTags, getPostsByTag, calculateReadingTime } from '../../lib/posts';
import { formatDateISO } from '../../lib/utils';

export async function getStaticPaths() {
  const tags = await getAllTags();
  
  return tags.map(tag => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;

const posts = await getPostsByTag(tag);
const allTags = await getAllTags();
---

<Layout title={`tag/${tag}`} description={`Artículos etiquetados con #${tag} | ${SITE.title}`}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Prompt del header -->
    <div class="mb-4 text-[var(--text-dim)] text-sm">
      {TERMINAL_PROMPTS.tag(tag)}
    </div>

    <!-- Header -->
    <header class="mb-8">
      <h1 class="text-xl font-bold text-[var(--text-primary)] mb-2">
        #{tag}
      </h1>
      
      <p class="text-[var(--text-secondary)] text-sm">
        {posts.length} {posts.length === 1 ? 'artículo' : 'artículos'} con este tag
      </p>
    </header>

    <!-- Tags filter -->
    {allTags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-3">
        <a 
          href={ROUTES.posts}
          class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] text-sm transition-colors"
        >
          {NAV_LABELS.all}
        </a>
        {allTags.filter(t => t !== tag).map(otherTag => (
          <a 
            href={`/tag/${otherTag}`}
            class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] text-sm transition-colors"
          >
            #{otherTag}
          </a>
        ))}
      </div>
    )}

    <!-- Lista de posts tipo terminal -->
    <div class="space-y-0">
      {posts.map((post) => {
        const readingTime = calculateReadingTime(post.body || '');
        return (
          <article class="row-terminal group">
            <a href={`${ROUTES.posts}/${post.id}`} class="contents">
              <!-- Fecha -->
              <span class="post-meta w-28 shrink-0">
                {formatDateISO(post.data.pubDatetime)}
              </span>
              
              <!-- Título -->
              <span class="row-title flex-1 text-[var(--text-primary)] transition-colors">
                {post.data.title}
              </span>
              
              <!-- Tags destacando el actual -->
              <span class="hidden sm:flex gap-2 shrink-0">
                {(post.data.tags || []).slice(0, CONTENT.maxTagsInList).map(t => (
                  <span class:list={[
                    "text-xs",
                    t === tag ? "text-[var(--accent-orange)]" : "text-[var(--accent-blue)]"
                  ]}>
                    #{t}
                  </span>
                ))}
              </span>
              
              <!-- Tiempo de lectura -->
              <span class="post-meta w-16 text-right shrink-0 hidden sm:block">
                {readingTime} min
              </span>
            </a>
          </article>
        );
      })}
    </div>

    <!-- Empty state -->
    {posts.length === 0 && (
      <div class="text-[var(--text-dim)] text-sm py-8">
        {MESSAGES.emptyTag}
      </div>
    )}

    <!-- Back link -->
    <div class="mt-12 pt-6 border-t border-[var(--border)]">
      <a href={ROUTES.posts} class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] text-sm transition-colors">
        ← {NAV_LABELS.backToPosts}
      </a>
    </div>

  </div>
</Layout>
