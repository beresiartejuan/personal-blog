---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';
import { Tag, ArrowLeft, Sparkles } from '@lucide/astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  const tags = [...new Set(posts.flatMap(post => post.data.tags || []))];
  
  return tags.map(tag => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props;

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => 
    !post.data.draft && 
    post.data.tags?.includes(tag)
  )
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime());

// Get all tags for filter
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))];
---

<Layout title={`#${tag}`} description={`Artículos etiquetados con #${tag}`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    
    <!-- Back Link -->
    <a href="/blog" class="inline-flex items-center gap-2 text-sm text-[#9AA3B2] hover:text-[#FF6B35] transition-colors mb-8">
      <ArrowLeft size={16} />
      Volver al blog
    </a>

    <!-- Header -->
    <header class="mb-12">
      <div class="flex items-center gap-3 mb-4">
        <Tag size={32} class="text-[#FF6B35]" />
        <h1 class="text-4xl md:text-5xl font-bold text-[#F1F5FB] tracking-tight">
          #{tag}
        </h1>
      </div>
      
      <p class="text-lg text-[#9AA3B2]">
        {posts.length} {posts.length === 1 ? 'artículo' : 'artículos'} etiquetados con este tema
      </p>
    </header>

    <!-- Other Tags -->
    <div class="mb-12">
      <p class="text-sm text-[#6B7280] mb-3">Otros temas:</p>
      <div class="flex flex-wrap gap-2">
        {allTags.filter(t => t !== tag).map(otherTag => (
          <a 
            href={`/tag/${otherTag}`}
            class="inline-flex items-center px-3 py-1.5 rounded-full text-sm bg-[#151A26] text-[#9AA3B2] border border-white/5 hover:border-[#FF6B35]/30 hover:text-[#FF6B35] transition-all"
          >
            #{otherTag}
          </a>
        ))}
      </div>
    </div>

    <!-- Posts -->
    <div class="space-y-6">
      {posts.map((post, index) => (
        <article class="group animate-fade-in-up">
          <a href={`/blog/${post.slug}`} class="block">
            <div class="bg-[#151A26] border border-white/5 rounded-xl p-6 hover:border-[#4A90E2]/30 hover:bg-[#1E2535] transition-all duration-300"
            style={`animation-delay: ${index * 0.1}s`}>
              <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-6">
                
                <!-- Date -->
                <div class="flex items-center gap-2 text-sm text-[#6B7280] md:w-32 shrink-0">
                  <span>{format(new Date(post.data.pubDatetime), 'd MMM yyyy', { locale: es })}</span>
                </div>
                
                <!-- Content -->
                <div class="flex-1">
                  <div class="flex items-center gap-3 mb-2">
                    <h2 class="text-xl font-semibold text-[#F1F5FB] group-hover:text-[#4A90E2] transition-colors">
                      {post.data.title}
                    </h2>
                    {post.data.featured && (
                      <Sparkles size={16} class="text-[#FF6B35]" />
                    )}
                  </div>
                  
                  <p class="text-[#9AA3B2] mb-3">
                    {post.data.description}
                  </p>
                  
                  <div class="flex flex-wrap gap-2">
                    {(post.data.tags || []).map(t => (
                      <span class:list={[
                        "inline-flex items-center px-2 py-0.5 rounded text-xs font-medium",
                        t === tag 
                          ? "bg-[#FF6B35]/20 text-[#FF6B35]" 
                          : "bg-[#0B0F17] text-[#9AA3B2]"
                      ]}>
                        #{t}
                      </span>
                    ))}
                  </div>
                </div>
                
                <!-- Arrow -->
                <div class="hidden md:flex items-center justify-center w-10 h-10 rounded-full bg-[#0B0F17] text-[#6B7280] group-hover:bg-[#FF6B35]/10 group-hover:text-[#FF6B35] transition-all"
003e
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" class="transform group-hover:translate-x-0.5 transition-transform">
                    <path d="M6 3L11 8L6 13" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>
            </div>
          </a>
        </article>
      ))}
    </div>

    <!-- Empty State -->
    {posts.length === 0 && (
      <div class="text-center py-16">
        <Tag size={48} class="text-[#6B7280] mx-auto mb-4" />
        <p class="text-[#9AA3B2] mb-2">No hay artículos etiquetados con #{tag}.</p>
        <a href="/blog" class="text-[#FF6B35] hover:underline">
          Ver todos los artículos
        </a>
      </div>
    )}

  </div>
</Layout>
