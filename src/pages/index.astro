---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE, SOCIAL, TERMINAL_PROMPTS, CONTENT, MESSAGES, ROUTES, ASSETS, formatDateISO, getReadingTime } from '../config';

// Obtener posts
const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime());

const totalPosts = posts.length;
---

<Layout 
  title={undefined}
  description={SITE.defaultDescription}
>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Header con perfil -->
    <header class="mb-12 border-b border-[var(--border)] pb-8">
      <div class="flex flex-col sm:flex-row gap-6 sm:gap-8">
        <!-- Foto de perfil -->
        <div class="shrink-0">
          <a href={ROUTES.about} class="block w-24 h-24 sm:w-28 sm:h-28 rounded-lg overflow-hidden border border-[var(--border)] bg-[var(--bg-secondary)] hover:border-[var(--accent-orange)] transition-colors">
            <img 
              src={ASSETS.profilePhotos[0]} 
              alt={SITE.author}
              class="w-full h-full object-cover"
            />
          </a>
        </div>

        <!-- Info del autor -->
        <div class="flex-1">
          <h1 class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)] mb-2">
            {SITE.author}
          </h1>
          <p class="text-[var(--text-secondary)] leading-relaxed mb-4 max-w-lg">
            Desarrollador web. Escribo sobre JavaScript, Astro, y mi viaje de aprendizaje en el mundo del desarrollo.
          </p>
          
          <!-- Stats rápidos -->
          <div class="flex flex-wrap items-center gap-4 text-sm text-[var(--text-dim)]">
            <span class="flex items-center gap-1.5">
              <span class="w-2 h-2 rounded-full bg-[var(--accent-orange)]"></span>
              {totalPosts} posts
            </span>
            <span>·</span>
            <div class="flex items-center gap-3">
              <a 
                href={SOCIAL.github} 
                target="_blank" 
                rel="noopener noreferrer"
                class="hover:text-[var(--accent-orange)] transition-colors"
              >
                github
              </a>
              <a 
                href={SOCIAL.linkedin} 
                target="_blank" 
                rel="noopener noreferrer"
                class="hover:text-[var(--accent-orange)] transition-colors"
              >
                linkedin
              </a>
            </div>
          </div>
        </div>
      </div>
    </header>

    <!-- Prompt del terminal -->
    <div class="mb-8 text-[var(--text-dim)] text-sm">
      {TERMINAL_PROMPTS.home}
    </div>

    <!-- Lista de posts tipo terminal -->
    <div class="space-y-0">
      {posts.map((post) => {
        const readingTime = getReadingTime(post.body || '');
        return (
          <article class="row-terminal-vertical group">
            <a href={`${ROUTES.posts}/${post.id}`} class="block py-5">
              <!-- Fila 1: Fecha y tiempo de lectura -->
              <div class="flex items-center gap-3 mb-2">
                <span class="post-meta">
                  {formatDateISO(post.data.pubDatetime)}
                </span>
                <span class="text-[var(--text-dim)]">·</span>
                <span class="post-meta">
                  {readingTime} min
                </span>
              </div>
              
              <!-- Fila 2: Título -->
              <h2 class="text-[var(--text-primary)] font-semibold text-base mb-3 group-hover:text-[var(--accent-orange)] transition-colors leading-tight">
                {post.data.title}
              </h2>
              
              <!-- Fila 3: Tags -->
              {(post.data.tags || []).length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {post.data.tags.slice(0, CONTENT.maxTagsInCard).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              )}
            </a>
          </article>
        );
      })}
    </div>

    <!-- Empty state -->
    {posts.length === 0 && (
      <div class="text-[var(--text-dim)] text-sm py-8">
        {MESSAGES.emptyPosts}
      </div>
    )}

    <!-- CTA estilo comando y contador de posts -->
    {posts.length > 0 && (
      <div class="mt-8 pt-6 border-t border-[var(--border)] flex items-center justify-between">
        <a href={ROUTES.posts} class="group flex items-center gap-2 text-[var(--text-secondary)] hover:text-[var(--accent-orange)] transition-colors">
          <span class="text-[var(--text-dim)]">$</span>
          <span class="text-base">ver-todos --posts</span>
          <span class="text-xl group-hover:translate-x-1 transition-transform">→</span>
        </a>
        
        <span class="text-[var(--text-dim)] text-sm">
          {posts.length} posts publicados
        </span>
      </div>
    )}
  </div>
</Layout>
