---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE, ROUTES, TERMINAL_PROMPTS, CONTENT, MESSAGES, NAV_LABELS, formatDateISO, getReadingTime } from '../config';

const posts = await getCollection('blog');
const postsData = posts
  .filter(post => !post.data.draft)
  .map(post => ({
    slug: post.id,
    title: post.data.title,
    description: post.data.description,
    tags: post.data.tags || [],
    pubDatetime: post.data.pubDatetime,
    body: post.body || '',
  }));
---

<Layout title="buscar" description={`Buscar artículos en el blog | ${SITE.title}`}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Prompt del header -->
    <div class="mb-8 text-[var(--text-dim)] text-sm">
      {TERMINAL_PROMPTS.search}
    </div>

    <!-- Search input -->
    <div class="mb-8">
      <div class="flex items-center gap-2 border border-[var(--border)] rounded bg-[var(--bg-secondary)] px-4 py-3">
        <span class="text-[var(--text-dim)]">></span>
        <input 
          type="text" 
          id="search-input"
          placeholder="buscar..."
          class="flex-1 bg-transparent border-none outline-none text-[var(--text-primary)] placeholder-[var(--text-dim)]"
          autocomplete="off"
          autofocus
        />
      </div>
    </div>
    
    <!-- Results -->
    <div id="search-results" class="space-y-0">
      <p class="text-[var(--text-dim)] text-sm py-8">
        {MESSAGES.searchPrompt}
      </p>
    </div>
    
    <!-- No Results -->
    <div id="no-results" class="hidden">
      <p class="text-[var(--text-dim)] text-sm py-8">{MESSAGES.emptySearch}</p>
    </div>

  </div>
</Layout>

<script is:inline data-posts-data={JSON.stringify(postsData)}>
  const postsData = JSON.parse(document.currentScript.dataset.postsData);
  
  const searchInput = document.getElementById('search-input');
  const searchResults = document.getElementById('search-results');
  const noResults = document.getElementById('no-results');
  
  function formatDate(dateString) {
    const date = new Date(dateString);
    return date.toISOString().split('T')[0];
  }
  
  function getReadingTime(body) {
    const words = body.split(/\s+/).length;
    return Math.ceil(words / 200);
  }
  
  function highlightMatch(text, query) {
    if (!query) return text;
    const regex = new RegExp(`(${query})`, 'gi');
    return text.replace(regex, '<span class="text-[var(--accent-orange)]">$1</span>');
  }
  
  function performSearch(query) {
    const normalizedQuery = query.toLowerCase().trim();
    
    if (!normalizedQuery) {
      searchResults.innerHTML = '<p class="text-[var(--text-dim)] text-sm py-8">Escribe para buscar artículos...</p>';
      noResults.classList.add('hidden');
      return;
    }
    
    const results = postsData.filter(post => 
      post.title.toLowerCase().includes(normalizedQuery) ||
      post.description.toLowerCase().includes(normalizedQuery) ||
      post.tags.some(tag => tag.toLowerCase().includes(normalizedQuery))
    );
    
    if (results.length === 0) {
      searchResults.innerHTML = '';
      noResults.classList.remove('hidden');
      return;
    }
    
    noResults.classList.add('hidden');
    
    searchResults.innerHTML = results.map(post => {
      const readingTime = getReadingTime(post.body);
      return `
        <article class="row-terminal group">
          <a href="/blog/${post.slug}" class="contents">
            <span class="post-meta w-28 shrink-0">
              ${formatDate(post.pubDatetime)}
            </span>
            
            <span class="row-title flex-1 text-[var(--text-primary)] transition-colors">
              ${highlightMatch(post.title, normalizedQuery)}
            </span>
            
            <span class="hidden sm:flex gap-2 shrink-0">
              ${post.tags.slice(0, 3).map(tag => 
                `<span class="tag">#${tag}</span>`
              ).join('')}
            </span>
            
            <span class="post-meta w-16 text-right shrink-0 hidden sm:block">
              ${readingTime} min
            </span>
          </a>
        </article>
      `;
    }).join('');
  }
  
  searchInput?.addEventListener('input', (e) => {
    performSearch(e.target.value);
  });
  
  // Focus on load
  searchInput?.focus();
</script>
