---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SITE, SOCIAL, TERMINAL_PROMPTS, NAV_LABELS, ASSETS, ANIMATION } from '../config';

const posts = await getCollection('blog');
const publishedPosts = posts.filter(post => !post.data.draft);
const totalPosts = publishedPosts.length;
---

<Layout title="sobre-mi" description={`${SITE.author} - Desarrollador web y creador de contenido`}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Prompt del header -->
    <div class="mb-8 text-[var(--text-dim)] text-sm">
      {TERMINAL_PROMPTS.about}
    </div>

    <!-- Información básica con foto -->
    <section class="mb-12">
      <div class="flex flex-col sm:flex-row gap-8 sm:gap-10 mb-6">
        <!-- Foto de perfil interactiva -->
        <div class="shrink-0">
          <div 
            id="profile-photo"
            class="w-44 h-44 sm:w-52 sm:h-52 rounded-lg overflow-hidden border border-[var(--border)] bg-[var(--bg-secondary)] cursor-pointer transition-transform duration-150 ease-out hover:scale-[1.02] active:scale-95 select-none"
          >
            <img 
              src={ASSETS.profilePhotos[0]} 
              alt={SITE.author}
              class="w-full h-full object-cover pointer-events-none"
            />
          </div>
        </div>

        <!-- Info -->
        <div class="flex-1">
          <h1 class="text-2xl font-bold text-[var(--text-primary)] mb-2">
            {SITE.author}
          </h1>
          
          <p class="text-[var(--text-secondary)] leading-relaxed mb-4">
            Desarrollador web. Escribo sobre JavaScript, Astro, y mi viaje de aprendizaje.
          </p>

          <!-- Links -->
          <div class="flex flex-wrap gap-4 text-sm">
            <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">
              github
            </a>
            <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">
              linkedin
            </a>
            <a href={SOCIAL.instagram} target="_blank" rel="noopener noreferrer">
              instagram
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Stats tipo terminal -->
    <section class="mb-12">
      <div class="text-[var(--text-dim)] text-sm mb-4">$ stats --summary</div>
      
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 text-sm">
        <div class="border border-[var(--border)] rounded px-4 py-3">
          <div class="text-[var(--accent-orange)] font-semibold">{totalPosts}</div>
          <div class="text-[var(--text-dim)]">{NAV_LABELS.posts}</div>
        </div>
        
        <div class="border border-[var(--border)] rounded px-4 py-3">
          <div class="text-[var(--text-primary)] font-semibold">ES</div>
          <div class="text-[var(--text-dim)]">idioma</div>
        </div>
        
      </div>
    </section>

    <!-- Bio -->
    <section class="mb-12">
      <div class="text-[var(--text-dim)] text-sm mb-4">$ cat bio.txt</div>
      
      <div class="text-[var(--text-secondary)] leading-relaxed space-y-4">
        <p>
          Me especializo en el ecosistema JavaScript moderno. Me interesa Astro, React 
          y todo lo relacionado con performance web.
        </p>
        
        <p>
          Creo que la mejor manera de aprender es enseñando. Este blog es mi espacio 
          para documentar lo que aprendo y compartirlo.
        </p>
        
        <p>
          Cuando no estoy codeando, probablemente estoy leyendo sobre nuevas tecnologías 
          o disfrutando de un buen café.
        </p>
      </div>
    </section>

    <!-- Quote -->
    <section>
      <div class="text-[var(--text-dim)] text-sm mb-4">$ echo $PHILOSOPHY</div>
      
      <blockquote class="border-l-2 border-[var(--accent-orange)] pl-4 text-[var(--text-secondary)] italic">
        "El mejor modo de predecir el futuro es inventarlo."
        <cite class="block mt-2 text-[var(--text-dim)] not-italic text-sm">
          — Alan Kay
        </cite>
      </blockquote>
    </section>

  </div>

  <script define:vars={{ profilePhotos: ASSETS.profilePhotos, animationDuration: ANIMATION.pressDuration }}>
    const photo = document.getElementById('profile-photo');
    const img = photo?.querySelector('img');
    
    let currentPhotoIndex = 0;
    
    photo?.addEventListener('click', () => {
      // Animación de "press" al hacer click
      photo.style.transform = 'scale(0.92)';
      
      // Rotar al siguiente foto en el array
      if (img) {
        currentPhotoIndex = (currentPhotoIndex + 1) % profilePhotos.length;
        img.src = profilePhotos[currentPhotoIndex];
      }
      
      setTimeout(() => {
        photo.style.transform = '';
      }, animationDuration);
    });
  </script>
</Layout>
