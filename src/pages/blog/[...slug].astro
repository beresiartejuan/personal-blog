---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { format } from 'date-fns';
import { es } from 'date-fns/locale';
import { SITE, ROUTES, NAV_LABELS, CONTENT, formatDateISO, getReadingTime } from '../../config';

// Static paths
export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Get prev/next posts for navigation
const allPosts = await getCollection('blog');
const sortedPosts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime());

const currentIndex = sortedPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < sortedPosts.length - 1 ? sortedPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? sortedPosts[currentIndex - 1] : null;

const readingTime = getReadingTime(post.body || '');
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Metadata arriba -->
    <header class="mb-8">
      <!-- Fecha, tags y tiempo de lectura -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-6 text-sm text-[var(--text-secondary)]">
        <span>{format(new Date(post.data.pubDatetime), CONTENT.dateFormat)}</span>
        <span class="text-[var(--text-dim)]">·</span>
        
        <span>{readingTime} min lectura</span>
        
        {post.data.modDatetime && (
          <>
            <span class="text-[var(--text-dim)]">·</span>
            <span>actualizado {format(new Date(post.data.modDatetime), CONTENT.dateFormat)}</span>
          </>
        )}
      </div>

      <!-- Tags -->
      {(post.data.tags || []).length > 0 && (
        <div class="flex flex-wrap gap-3 mb-6">
          {post.data.tags.map(tag => (
            <a href={`/tag/${tag}`} class="tag">
              #{tag}
            </a>
          ))}
        </div>
      )}
      
      <!-- Título -->
      <h1 class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)] mb-6">
        {post.data.title}
      </h1>
      
      <!-- Descripción -->
      <p class="text-[var(--text-secondary)] text-base leading-relaxed">
        {post.data.description}
      </p>
    </header>

    <!-- Contenido -->
    <div class="prose prose-lg">
      <Content />
    </div>

    <!-- Navegación anterior/siguiente -->
    <nav class="nav-posts">
      <div>
        {prevPost && (
          <a href={`${ROUTES.posts}/${prevPost.id}`} class="flex items-center gap-2">
            <span>←</span>
            <span class="hidden sm:inline">{prevPost.data.title}</span>
            <span class="sm:hidden">{NAV_LABELS.previous}</span>
          </a>
        )}
      </div>
      
      <div>
        {nextPost && (
          <a href={`${ROUTES.posts}/${nextPost.id}`} class="flex items-center gap-2">
            <span class="hidden sm:inline">{nextPost.data.title}</span>
            <span class="sm:hidden">{NAV_LABELS.next}</span>
            <span>→</span>
          </a>
        )}
      </div>
    </nav>

  </article>
</Layout>
