---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';
import { SITE, ROUTES, NAV_LABELS } from '../../config';
import { getPrevNextPosts, calculateReadingTime } from '../../lib/posts';
import { formatDate } from '../../lib/utils';
import CommentsSection from '../../components/comments/CommentsSection.astro';

// SSR mode - obtener el slug de los params
const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/404');
}

// Buscar el post por slug
const posts = await getCollection('blog');
const post = posts.find(p => p.id === slug);

if (!post || post.data.draft) {
  return Astro.redirect('/404');
}

const { Content } = await render(post);

// Get prev/next posts for navigation
const { prevPost, nextPost } = await getPrevNextPosts(post.id);

const readingTime = calculateReadingTime(post.body || '');
---

<Layout title={post.data.title} description={post.data.description}>
  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Metadata arriba -->
    <header class="mb-8">
      <!-- Fecha, tags y tiempo de lectura -->
      <div class="flex flex-wrap items-center gap-x-4 gap-y-2 mb-6 text-sm text-[var(--text-secondary)]">
        <span>{formatDate(post.data.pubDatetime)}</span>
        <span class="text-[var(--text-dim)]">·</span>
        
        <span>{readingTime} min lectura</span>
        
        {post.data.modDatetime && (
          <>
            <span class="text-[var(--text-dim)]">·</span>
            <span>actualizado {formatDate(post.data.modDatetime)}</span>
          </>
        )}
      </div>

      <!-- Tags -->
      {(post.data.tags || []).length > 0 && (
        <div class="flex flex-wrap gap-3 mb-6">
          {post.data.tags.map(tag => (
            <a href={`/tag/${tag}`} class="tag">
              #{tag}
            </a>
          ))}
        </div>
      )}
      
      <!-- Título -->
      <h1 class="text-2xl sm:text-3xl font-bold text-[var(--text-primary)] mb-6">
        {post.data.title}
      </h1>
      
      <!-- Descripción -->
      <p class="text-[var(--text-secondary)] text-base leading-relaxed">
        {post.data.description}
      </p>
    </header>

    <!-- Contenido -->
    <div class="prose prose-lg">
      <Content />
    </div>

    <!-- Navegación anterior/siguiente -->
    <nav class="nav-posts">
      <div>
        {prevPost && (
          <a href={`${ROUTES.posts}/${prevPost.id}`} class="flex items-center gap-2">
            <span>←</span>
            <span class="hidden sm:inline">{prevPost.data.title}</span>
            <span class="sm:hidden">{NAV_LABELS.previous}</span>
          </a>
        )}
      </div>
      
      <div>
        {nextPost && (
          <a href={`${ROUTES.posts}/${nextPost.id}`} class="flex items-center gap-2">
            <span class="hidden sm:inline">{nextPost.data.title}</span>
            <span class="sm:hidden">{NAV_LABELS.next}</span>
            <span>→</span>
          </a>
        )}
      </div>
    </nav>

    <!-- Sección de comentarios -->
    <CommentsSection postSlug={post.id} />

  </article>
</Layout>
