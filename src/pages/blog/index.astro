---
import Layout from '../../layouts/Layout.astro';
import { SITE, ROUTES, NAV_LABELS, TERMINAL_PROMPTS, CONTENT, MESSAGES } from '../../config';
import { getSortedPosts, getAllTags, calculateReadingTime } from '../../lib/posts';
import { formatDateISO } from '../../lib/utils';

const posts = await getSortedPosts();
const allTags = await getAllTags();
---

<Layout title="posts" description={`Todos los artículos sobre desarrollo web, JavaScript y más | ${SITE.title}`}>
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Prompt del header -->
    <div class="mb-12 text-[var(--text-dim)] text-sm">
      {TERMINAL_PROMPTS.posts}
    </div>

    <!-- Tags filter -->
    {allTags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-3">
        <a 
          href={ROUTES.posts}
          class="text-[var(--accent-orange)] text-sm border-b border-[var(--accent-orange)] pb-0.5"
        >
          {NAV_LABELS.all}
        </a>
        {allTags.map(tag => (
          <a 
            href={`/tag/${tag}`}
            class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] text-sm transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Lista de posts tipo terminal -->
    <div class="space-y-0">
      {posts.map((post) => {
        const readingTime = calculateReadingTime(post.body || '');
        return (
          <article class="row-terminal group">
            <a href={`${ROUTES.posts}/${post.id}`} class="contents">
              <!-- Fecha -->
              <span class="post-meta">
                {formatDateISO(post.data.pubDatetime)}
              </span>
              
              <!-- Título -->
              <span class="row-title text-[var(--text-primary)] transition-colors">
                {post.data.title}
              </span>
              
              <!-- Tags -->
              <span class="hidden sm:flex gap-2">
                {(post.data.tags || []).slice(0, CONTENT.maxTagsInList).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </span>
              
              <!-- Tiempo de lectura -->
              <span class="post-meta text-right hidden sm:block">
                {readingTime} min
              </span>
            </a>
          </article>
        );
      })}
    </div>

    <!-- Empty state -->
    {posts.length === 0 && (
      <div class="text-[var(--text-dim)] text-sm py-8">
        {MESSAGES.emptyPosts}
      </div>
    )}

  </div>
</Layout>
