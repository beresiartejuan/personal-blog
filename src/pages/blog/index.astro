---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .filter(post => !post.data.draft)
  .sort((a, b) => new Date(b.data.pubDatetime).getTime() - new Date(a.data.pubDatetime).getTime());

// Obtener todos los tags únicos
const allTags = [...new Set(allPosts.flatMap(post => post.data.tags || []))].sort();

// Función para formatear fecha YYYY-MM-DD
function formatDate(date: Date): string {
  return date.toISOString().split('T')[0];
}

// Calcular tiempo de lectura aproximado
function getReadingTime(body: string): number {
  const words = body.split(/\s+/).length;
  return Math.ceil(words / 200);
}
---

<Layout title="posts" description="Todos los artículos sobre desarrollo web, JavaScript y más">
  <div class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    
    <!-- Prompt del header -->
    <div class="mb-12 text-[var(--text-dim)] text-sm">
      ~/blog/posts $
    </div>

    <!-- Tags filter -->
    {allTags.length > 0 && (
      <div class="mb-8 flex flex-wrap gap-3">
        <a 
          href="/blog" 
          class="text-[var(--accent-orange)] text-sm border-b border-[var(--accent-orange)] pb-0.5"
        >
          todos
        </a>
        {allTags.map(tag => (
          <a 
            href={`/tag/${tag}`}
            class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] text-sm transition-colors"
          >
            #{tag}
          </a>
        ))}
      </div>
    )}

    <!-- Lista de posts tipo terminal -->
    <div class="space-y-0">
      {posts.map((post) => {
        const readingTime = getReadingTime(post.body || '');
        return (
          <article class="row-terminal group">
            <a href={`/blog/${post.id}`} class="contents">
              <!-- Fecha -->
              <span class="post-meta">
                {formatDate(post.data.pubDatetime)}
              </span>
              
              <!-- Título -->
              <span class="row-title text-[var(--text-primary)] transition-colors">
                {post.data.title}
              </span>
              
              <!-- Tags -->
              <span class="hidden sm:flex gap-2">
                {(post.data.tags || []).slice(0, 3).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </span>
              
              <!-- Tiempo de lectura -->
              <span class="post-meta text-right hidden sm:block">
                {readingTime} min
              </span>
            </a>
          </article>
        );
      })}
    </div>

    <!-- Empty state -->
    {posts.length === 0 && (
      <div class="text-[var(--text-dim)] text-sm py-8">
        No hay posts publicados todavía.
      </div>
    )}

  </div>
</Layout>
