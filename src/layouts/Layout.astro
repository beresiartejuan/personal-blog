---
import { Search, Menu, X } from '@lucide/astro';
import './../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = "Un blog sobre desarrollo web, experiencias y aprendizajes" } = Astro.props;
const pageTitle = title ? `${title} | Juan Beresiarte` : "Juan Beresiarte";
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="sticky top-0 z-50 backdrop-blur-md bg-[#0B0F17]/80 border-b border-white/5">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2 group">
            <span class="text-2xl font-bold text-[#F1F5FB] tracking-tight group-hover:text-[#FF6B35] transition-colors">
              JB
            </span>
            <span class="hidden sm:block text-lg font-medium text-[#9AA3B2] group-hover:text-[#F1F5FB] transition-colors">
              Juan Beresiarte
            </span>
          </a>

          <!-- Desktop Navigation -->
          <nav class="hidden md:flex items-center gap-8">
            <a href="/" class="text-sm font-medium text-[#9AA3B2] hover:text-[#F1F5FB] transition-colors relative group">
              Inicio
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FF6B35] group-hover:w-full transition-all duration-300"></span>
            </a>
            <a href="/blog" class="text-sm font-medium text-[#9AA3B2] hover:text-[#F1F5FB] transition-colors relative group">
              Blog
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FF6B35] group-hover:w-full transition-all duration-300"></span>
            </a>
            <a href="/sobre-mi" class="text-sm font-medium text-[#9AA3B2] hover:text-[#F1F5FB] transition-colors relative group">
              Sobre mí
              <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-[#FF6B35] group-hover:w-full transition-all duration-300"></span>
            </a>
          </nav>

          <!-- Search & Mobile Menu -->
          <div class="flex items-center gap-4">
            <a href="/buscar" class="p-2 text-[#9AA3B2] hover:text-[#F1F5FB] hover:bg-white/5 rounded-lg transition-all" aria-label="Buscar">
              <Search size={20} />
            </a>
            
            <!-- Mobile Menu Button -->
            <button id="mobile-menu-btn" class="md:hidden p-2 text-[#9AA3B2] hover:text-[#F1F5FB] hover:bg-white/5 rounded-lg transition-all" aria-label="Menú">
              <Menu size={24} id="menu-icon" />
              <X size={24} id="close-icon" class="hidden" />
            </button>
          </div>
        </div>

        <!-- Mobile Navigation -->
        <div id="mobile-menu" class="hidden md:hidden pb-4">
          <nav class="flex flex-col gap-2 pt-4 border-t border-white/5">
            <a href="/" class="px-3 py-2 text-[#9AA3B2] hover:text-[#F1F5FB] hover:bg-white/5 rounded-lg transition-all">
              Inicio
            </a>
            <a href="/blog" class="px-3 py-2 text-[#9AA3B2] hover:text-[#F1F5FB] hover:bg-white/5 rounded-lg transition-all">
              Blog
            </a>
            <a href="/sobre-mi" class="px-3 py-2 text-[#9AA3B2] hover:text-[#F1F5FB] hover:bg-white/5 rounded-lg transition-all">
              Sobre mí
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="border-t border-white/5 bg-[#0B0F17]">
      <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
        <div class="flex flex-col md:flex-row items-center justify-between gap-4">
          <p class="text-sm text-[#6B7280]">
            © {new Date().getFullYear()} Juan Beresiarte. Escrito con intención.
          </p>
          <div class="flex items-center gap-6">
            <a href="https://github.com/beresiarte" target="_blank" rel="noopener noreferrer" class="text-[#6B7280] hover:text-[#FF6B35] transition-colors text-sm">
              GitHub
            </a>
            <a href="https://linkedin.com/in/beresiarte" target="_blank" rel="noopener noreferrer" class="text-[#6B7280] hover:text-[#FF6B35] transition-colors text-sm">
              LinkedIn
            </a>
            <a href="https://instagram.com/beresiarte" target="_blank" rel="noopener noreferrer" class="text-[#6B7280] hover:text-[#FF6B35] transition-colors text-sm">
              Instagram
            </a>
          </div>
        </div>
      </div>
    </footer>

    <script>
      const mobileMenuBtn = document.getElementById('mobile-menu-btn');
      const mobileMenu = document.getElementById('mobile-menu');
      const menuIcon = document.getElementById('menu-icon');
      const closeIcon = document.getElementById('close-icon');

      if (mobileMenuBtn && mobileMenu && menuIcon && closeIcon) {
        mobileMenuBtn.addEventListener('click', () => {
          mobileMenu.classList.toggle('hidden');
          menuIcon.classList.toggle('hidden');
          closeIcon.classList.toggle('hidden');
        });
      }
    </script>
  </body>
</html>
