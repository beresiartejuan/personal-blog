---
import './../styles/global.css';
import { SITE, SOCIAL, ROUTES, NAV_LABELS, TERMINAL_PROMPTS, ASSETS, EXTERNAL, getPageTitle } from '../config';

interface Props {
  title?: string;
  description?: string;
}

const { title, description = SITE.defaultDescription } = Astro.props;
const pageTitle = getPageTitle(title);
const currentYear = new Date().getFullYear();
---

<!DOCTYPE html>
<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href={ASSETS.faviconSvg} />
    <link rel="icon" type="image/x-icon" href={ASSETS.faviconIco} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href={EXTERNAL.googleFontsPreconnect}>
    <link rel="preconnect" href={EXTERNAL.googleFontsGStatic} crossorigin>
    <link href={EXTERNAL.googleFontsStylesheet} rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-[var(--border)] bg-[var(--bg-secondary)]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <!-- Prompt -->
          <a href={ROUTES.home} class="header-prompt cursor-blink hover:text-[var(--text-primary)] transition-colors">
            {TERMINAL_PROMPTS.home.replace(' $', '')}
          </a>

          <!-- Navigation -->
          <nav class="flex items-center gap-6 text-sm">
            <a href={ROUTES.posts} class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] transition-colors">
              {NAV_LABELS.posts}
            </a>
            <a href={ROUTES.search} class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] transition-colors">
              {NAV_LABELS.search}
            </a>
            <a href={ROUTES.about} class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] transition-colors">
              {NAV_LABELS.about}
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="footer-minimal py-6">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 flex items-center justify-between">
        <span>© {currentYear}</span>
        <div class="flex items-center gap-4">
          <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">
            github
          </a>
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">
            linkedin
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
