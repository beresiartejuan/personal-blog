---
import './../styles/global.css';
import { SEO } from "astro-seo";
import { SITE, SOCIAL, ROUTES, NAV_LABELS, TERMINAL_PROMPTS, ASSETS, EXTERNAL, getPageTitle } from '../config';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonicalURL?: string;
  noindex?: boolean;
}

const { 
  title, 
  description = SITE.defaultDescription,
  ogImage = ASSETS.profilePhotos[0],
  canonicalURL,
  noindex = false,
} = Astro.props;

const pageTitle = getPageTitle(title);
const currentYear = new Date().getFullYear();

const fullCanonicalURL = canonicalURL ? `${SITE.url}${canonicalURL}` : `${SITE.url}${Astro.url.pathname}`;
const fullOgImageURL = `${SITE.url}${ogImage}`;
---

<!DOCTYPE html>
<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <SEO
      title={pageTitle}
      description={description}
      canonical={fullCanonicalURL}
      noindex={noindex}
      openGraph={{
        basic: {
          title: pageTitle,
          type: "website",
          image: fullOgImageURL,
        },
        optional: {
          description: description,
          siteName: SITE.title,
        },
        image: {
          alt: `Imagen de ${SITE.author}`,
        },
      }}
      twitter={{
        card: "summary_large_image",
        site: "@beresiarte",
        creator: "@beresiarte",
        title: pageTitle,
        description: description,
        image: fullOgImageURL,
        imageAlt: `Imagen de ${SITE.author}`,
      }}
      extend={{
        link: [
          { rel: "icon", type: "image/svg+xml", href: ASSETS.faviconSvg },
          { rel: "icon", type: "image/x-icon", href: ASSETS.faviconIco },
          { rel: "preconnect", href: EXTERNAL.googleFontsPreconnect },
          { rel: "preconnect", href: EXTERNAL.googleFontsGStatic, crossorigin: "anonymous" },
        ],
        meta: [
          { name: "author", content: SITE.author },
        ],
      }}
    />
    <link href={EXTERNAL.googleFontsStylesheet} rel="stylesheet">
  </head>
  <body class="min-h-screen flex flex-col">
    <header class="border-b border-[var(--border)] bg-[var(--bg-secondary)]">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <div class="flex items-center justify-between h-14">
          <!-- Prompt -->
          <a href={ROUTES.home} class="header-prompt cursor-blink hover:text-[var(--text-primary)] transition-colors">
            {TERMINAL_PROMPTS.home.replace(' $', '')}
          </a>

          <!-- Navigation -->
          <nav class="flex items-center gap-6 text-sm">
            <a href={ROUTES.posts} class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] transition-colors">
              {NAV_LABELS.posts}
            </a>
            <a href={ROUTES.search} class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] transition-colors">
              {NAV_LABELS.search}
            </a>
            <a href={ROUTES.about} class="text-[var(--text-secondary)] hover:text-[var(--accent-orange)] transition-colors">
              {NAV_LABELS.about}
            </a>
          </nav>
        </div>
      </div>
    </header>

    <main class="flex-1">
      <slot />
    </main>

    <footer class="footer-minimal py-6">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 flex items-center justify-between">
        <span>© {currentYear}</span>
        <div class="flex items-center gap-4">
          <a href={SOCIAL.github} target="_blank" rel="noopener noreferrer">
            github
          </a>
          <a href={SOCIAL.linkedin} target="_blank" rel="noopener noreferrer">
            linkedin
          </a>
        </div>
      </div>
    </footer>
  </body>
</html>
